# Supabase (optional for local dev; required in production for accounts + problems).

# Public — safe in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server only, NEVER prefix with NEXT_PUBLIC. Used by the /api routes
# to read the locked-down problems table. Get it from Supabase →
# Project Settings → API → service_role (secret) key.
SUPABASE_SERVICE_ROLE_KEY=
